<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🖤🐛 BlackBugsAI — Control Matrix</title>
<style>
:root {
  --bg: #0a0b0f;
  --bg2: #0f1117;
  --bg3: #141720;
  --card: #161b27;
  --card2: #1a2035;
  --border: #1e2a42;
  --border2: #253352;
  --accent: #4f8cff;
  --accent2: #6ea6ff;
  --green: #00e5a0;
  --red: #ff4d6a;
  --yellow: #ffd166;
  --purple: #b48bff;
  --cyan: #00d4ff;
  --text: #e2e8f5;
  --text2: #8899bb;
  --text3: #4a5a7a;
  --glow: 0 0 20px rgba(79,140,255,0.25);
  --glow-g: 0 0 20px rgba(0,229,160,0.25);
  --radius: 10px;
  --node-w: 200px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif; overflow: hidden; }

/* ─── LAYOUT ─────────────────────────────────────────────────── */
#app { display: grid; grid-template-rows: 48px 1fr; grid-template-columns: 240px 1fr 320px; height: 100vh; }
#topbar { grid-column: 1/-1; display: flex; align-items: center; gap: 12px; padding: 0 16px; background: var(--bg2); border-bottom: 1px solid var(--border); z-index: 100; }
#sidebar { grid-row: 2; background: var(--bg2); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }
#canvas-area { grid-row: 2; position: relative; overflow: hidden; background: var(--bg); }
#right-panel { grid-row: 2; background: var(--bg2); border-left: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }

/* ─── TOPBAR ─────────────────────────────────────────────────── */
.logo { font-size: 18px; font-weight: 800; background: linear-gradient(135deg, var(--accent), var(--green)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.5px; white-space: nowrap; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
.topbar-section { display: flex; align-items: center; gap: 8px; }
.topbar-sep { width: 1px; height: 24px; background: var(--border); }
.btn { padding: 6px 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--card); color: var(--text2); font-size: 12px; cursor: pointer; transition: all .15s; display: flex; align-items: center; gap: 6px; white-space: nowrap; }
.btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(79,140,255,0.08); }
.btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
.btn.primary:hover { background: var(--accent2); }
.btn.danger { border-color: var(--red); color: var(--red); }
.btn.danger:hover { background: rgba(255,77,106,0.1); }
.btn.green { border-color: var(--green); color: var(--green); }
.btn.green:hover { background: rgba(0,229,160,0.08); }
.tunnel-badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; border: 1px solid var(--border); color: var(--text3); cursor: pointer; }
.tunnel-badge.active { border-color: var(--green); color: var(--green); background: rgba(0,229,160,0.08); }
.collab-avatars { display: flex; gap: -4px; }
.collab-av { width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--bg); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; margin-left: -4px; }
.ver-badge { font-size: 10px; color: var(--text3); padding: 2px 6px; border: 1px solid var(--border); border-radius: 4px; }
#ai-bar { flex: 1; max-width: 420px; position: relative; }
#ai-input { width: 100%; padding: 7px 36px 7px 36px; background: var(--card); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: 13px; outline: none; transition: border-color .15s; }
#ai-input:focus { border-color: var(--accent); }
#ai-input::placeholder { color: var(--text3); }
.ai-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 14px; }
.ai-send { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--accent); font-size: 16px; }

/* ─── SIDEBAR ────────────────────────────────────────────────── */
.sidebar-head { padding: 14px 14px 6px; font-size: 10px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }
.nav-item { display: flex; align-items: center; gap: 9px; padding: 8px 14px; cursor: pointer; font-size: 13px; color: var(--text2); border-radius: 6px; margin: 1px 6px; transition: all .12s; }
.nav-item:hover { background: var(--card); color: var(--text); }
.nav-item.active { background: rgba(79,140,255,0.12); color: var(--accent); }
.nav-item .badge { margin-left: auto; font-size: 10px; padding: 2px 6px; border-radius: 10px; background: var(--card2); color: var(--text2); }
.nav-item.active .badge { background: var(--accent); color: #fff; }
.sidebar-stats { margin: auto 0 0; border-top: 1px solid var(--border); }
.stat-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 14px; font-size: 12px; color: var(--text2); }
.stat-bar { height: 3px; background: var(--border); border-radius: 2px; flex: 1; margin: 0 8px; }
.stat-fill { height: 100%; border-radius: 2px; transition: width .5s; }

/* ─── CANVAS ─────────────────────────────────────────────────── */
#flow-canvas { position: absolute; inset: 0; }
.canvas-bg { position: absolute; inset: 0; background-image: radial-gradient(circle, var(--border) 1px, transparent 1px); background-size: 28px 28px; opacity: 0.5; }
#nodes-layer { position: absolute; inset: 0; transform-origin: 0 0; }
.canvas-controls { position: absolute; bottom: 16px; right: 16px; display: flex; flex-direction: column; gap: 4px; }
.canvas-btn { width: 32px; height: 32px; background: var(--card); border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 14px; color: var(--text2); transition: all .12s; }
.canvas-btn:hover { border-color: var(--accent); color: var(--accent); }
.minimap { position: absolute; bottom: 16px; left: 16px; width: 160px; height: 100px; background: var(--card); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }

/* ─── NODES ─────────────────────────────────────────────────── */
.node { position: absolute; width: var(--node-w); background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); cursor: move; transition: border-color .15s, box-shadow .15s; user-select: none; }
.node:hover { border-color: var(--border2); z-index: 10; }
.node.selected { border-color: var(--accent); box-shadow: var(--glow); z-index: 20; }
.node.running { border-color: var(--green); box-shadow: var(--glow-g); }
.node.error { border-color: var(--red); }
.node-head { padding: 10px 12px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border); }
.node-icon { font-size: 18px; }
.node-title { font-size: 13px; font-weight: 600; flex: 1; }
.node-status { width: 8px; height: 8px; border-radius: 50%; background: var(--text3); }
.node-status.ok { background: var(--green); }
.node-status.err { background: var(--red); }
.node-status.run { background: var(--yellow); animation: pulse 1s infinite; }
.node-body { padding: 8px 12px; font-size: 11px; color: var(--text2); }
.node-port { position: absolute; width: 10px; height: 10px; background: var(--bg); border: 2px solid var(--border); border-radius: 50%; cursor: crosshair; transition: border-color .12s; }
.node-port:hover { border-color: var(--accent); background: var(--accent); }
.node-port.in { left: -5px; top: 50%; transform: translateY(-50%); }
.node-port.out { right: -5px; top: 50%; transform: translateY(-50%); }
.node-actions { padding: 6px 12px; display: flex; gap: 4px; border-top: 1px solid var(--border); }
.node-btn { flex: 1; padding: 4px; font-size: 10px; border-radius: 4px; border: 1px solid var(--border); background: none; color: var(--text2); cursor: pointer; transition: all .12s; }
.node-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ─── EDGES ─────────────────────────────────────────────────── */
#edges-svg { position: absolute; inset: 0; pointer-events: none; overflow: visible; }
.edge { fill: none; stroke: var(--border2); stroke-width: 2; }
.edge.active { stroke: var(--accent); opacity: 0.6; }
.edge.data-flow { stroke: var(--green); stroke-dasharray: 8 4; animation: flow 1s linear infinite; }
@keyframes flow { from{stroke-dashoffset:24} to{stroke-dashoffset:0} }

/* ─── COLLAB CURSORS ─────────────────────────────────────────── */
.collab-cursor { position: absolute; pointer-events: none; transition: all .08s; z-index: 1000; }
.collab-cursor-arrow { width: 0; height: 0; border-style: solid; border-width: 0 8px 14px 4px; }
.collab-cursor-label { font-size: 11px; font-weight: 600; padding: 2px 6px; border-radius: 4px; margin-top: 4px; white-space: nowrap; }

/* ─── RIGHT PANEL ────────────────────────────────────────────── */
.panel-tabs { display: flex; border-bottom: 1px solid var(--border); }
.panel-tab { flex: 1; padding: 10px 4px; font-size: 12px; text-align: center; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; transition: all .12s; }
.panel-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.panel-content { flex: 1; overflow-y: auto; }
.panel-content::-webkit-scrollbar { width: 4px; }
.panel-content::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* ─── LOGS ─────────────────────────────────────────────────── */
#logs-panel { padding: 8px; display: flex; flex-direction: column; gap: 1px; }
.log-entry { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-family: 'JetBrains Mono', 'Fira Code', monospace; line-height: 1.5; border-left: 2px solid transparent; }
.log-entry.INFO { border-left-color: var(--accent); background: rgba(79,140,255,0.04); }
.log-entry.WARN { border-left-color: var(--yellow); background: rgba(255,209,102,0.04); }
.log-entry.ERROR { border-left-color: var(--red); background: rgba(255,77,106,0.06); }
.log-ts { color: var(--text3); margin-right: 8px; }
.log-auto { padding: 8px; }
#log-input { width: 100%; background: none; border: none; color: var(--text3); font-size: 11px; resize: none; height: 16px; }

/* ─── TOOLS PANEL ────────────────────────────────────────────── */
.tools-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; padding: 8px; }
.tool-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 10px; cursor: pointer; transition: all .12s; }
.tool-card:hover { border-color: var(--accent); }
.tool-card .tc-icon { font-size: 20px; margin-bottom: 6px; }
.tool-card .tc-name { font-size: 12px; font-weight: 600; }
.tool-card .tc-desc { font-size: 10px; color: var(--text2); margin-top: 3px; line-height: 1.4; }
.tool-card .tc-status { display: flex; align-items: center; gap: 4px; margin-top: 6px; font-size: 10px; color: var(--green); }
.add-tool-btn { grid-column: 1/-1; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 12px; border: 1px dashed var(--border2); border-radius: 8px; color: var(--text3); font-size: 12px; cursor: pointer; transition: all .12s; }
.add-tool-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ─── AI CHAT ────────────────────────────────────────────────── */
#ai-chat { display: flex; flex-direction: column; height: 100%; }
#ai-messages { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.ai-msg { max-width: 90%; padding: 8px 12px; border-radius: 8px; font-size: 12px; line-height: 1.6; }
.ai-msg.user { background: rgba(79,140,255,0.15); border: 1px solid rgba(79,140,255,0.3); align-self: flex-end; color: var(--text); }
.ai-msg.bot { background: var(--card); border: 1px solid var(--border); align-self: flex-start; color: var(--text); }
.ai-msg.bot.thinking { opacity: 0.6; font-style: italic; }
.ai-msg-footer { font-size: 10px; color: var(--text3); margin-top: 4px; }
#ai-chat-input { display: flex; gap: 6px; padding: 10px; border-top: 1px solid var(--border); }
#ai-chat-text { flex: 1; background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 7px 10px; color: var(--text); font-size: 12px; resize: none; height: 36px; outline: none; }
#ai-chat-text:focus { border-color: var(--accent); }

/* ─── MODALS ─────────────────────────────────────────────────── */
.overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 500; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
.modal { background: var(--bg2); border: 1px solid var(--border2); border-radius: 14px; padding: 24px; width: 480px; max-width: 95vw; max-height: 85vh; overflow-y: auto; }
.modal h3 { font-size: 16px; font-weight: 700; margin-bottom: 16px; }
.field { margin-bottom: 14px; }
.field label { display: block; font-size: 12px; color: var(--text2); margin-bottom: 6px; }
.field input, .field textarea, .field select { width: 100%; padding: 8px 12px; background: var(--card); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 13px; outline: none; transition: border-color .12s; }
.field input:focus, .field textarea:focus { border-color: var(--accent); }
.field textarea { resize: vertical; min-height: 80px; font-family: 'JetBrains Mono', monospace; font-size: 12px; }
.steps-indicator { display: flex; gap: 6px; margin-bottom: 20px; }
.step-dot { flex: 1; height: 4px; border-radius: 2px; background: var(--border); transition: background .3s; }
.step-dot.done { background: var(--accent); }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }

/* ─── TOASTS ─────────────────────────────────────────────────── */
#toasts { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 8px; align-items: center; pointer-events: none; }
.toast { padding: 10px 18px; border-radius: 8px; font-size: 13px; background: var(--card2); border: 1px solid var(--border2); color: var(--text); animation: slideUp .25s ease; pointer-events: auto; max-width: 380px; }
.toast.ok { border-color: var(--green); color: var(--green); }
.toast.err { border-color: var(--red); color: var(--red); }
@keyframes slideUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

/* ─── SCROLLBARS ─────────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
::-webkit-scrollbar-track { background: transparent; }

/* ─── TOOL INSTALL STAGES ────────────────────────────────────── */
.install-stages { display: flex; flex-direction: column; gap: 6px; margin: 12px 0; }
.stage-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--card); border-radius: 6px; border: 1px solid var(--border); font-size: 12px; }
.stage-icon { font-size: 16px; min-width: 20px; }
.stage-done { border-color: var(--green); }
.stage-active { border-color: var(--accent); animation: stagePulse 1s infinite; }
.stage-error { border-color: var(--red); }
@keyframes stagePulse { 0%,100%{opacity:1}50%{opacity:.6} }

/* ─── SYSTEM METRICS ────────────────────────────────────────── */
.metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 10px; }
.metric-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 12px; }
.metric-val { font-size: 22px; font-weight: 800; margin: 4px 0; }
.metric-label { font-size: 10px; color: var(--text2); }
.metric-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 8px; }
.metric-fill { height: 100%; border-radius: 2px; background: var(--accent); }
.metric-fill.warn { background: var(--yellow); }
.metric-fill.crit { background: var(--red); }

/* ─── TUNNEL PANEL ────────────────────────────────────────────── */
.tunnel-panel { padding: 12px; }
.tunnel-url-box { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; font-family: monospace; font-size: 11px; color: var(--cyan); word-break: break-all; margin: 10px 0; }
.qr-placeholder { width: 100%; aspect-ratio: 1; background: var(--card); border: 1px solid var(--border); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--text3); font-size: 13px; max-width: 160px; margin: 10px auto; }
</style>
</head>
<body>
<div id="app">
  <!-- TOP BAR -->
  <div id="topbar">
    <div class="topbar-section">
      <span class="logo">🖤🐛 BlackBugsAI</span>
      <span class="ver-badge">v4.0</span>
      <span class="status-dot" id="global-dot"></span>
    </div>
    <div class="topbar-sep"></div>
    <div id="ai-bar">
      <span class="ai-icon">⚡</span>
      <input id="ai-input" placeholder="Скажи AI что сделать... (установи инструмент robin, запусти OSINT на domain.com)" autocomplete="off">
      <button class="ai-send" onclick="aiBarSend()">↵</button>
    </div>
    <div class="topbar-sep"></div>
    <div class="topbar-section" style="gap:6px">
      <span class="tunnel-badge" id="tunnel-badge" onclick="openTunnelPanel()">⚡ Tunnel: OFF</span>
      <button class="btn green" onclick="openAddTool()">+ Инструмент</button>
      <button class="btn" onclick="showModal('system-modal')">⚙️ Система</button>
    </div>
    <div class="topbar-sep"></div>
    <div class="collab-avatars" id="collab-avatars">
      <div class="collab-av" style="background:#4f8cff" title="Вы">Я</div>
    </div>
  </div>

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="sidebar-head">Навигация</div>
    <div class="nav-item active" onclick="setView('flow')" id="nav-flow">
      <span>⬡</span> Flow Canvas <span class="badge">Live</span>
    </div>
    <div class="nav-item" onclick="setView('tools')" id="nav-tools">
      <span>🔧</span> Инструменты <span class="badge" id="tools-count">0</span>
    </div>
    <div class="nav-item" onclick="setView('agents')" id="nav-agents">
      <span>🤖</span> Агенты
    </div>
    <div class="nav-item" onclick="setView('tunnel')" id="nav-tunnel">
      <span>🌐</span> Туннели
    </div>
    <div class="nav-item" onclick="setView('users')" id="nav-users">
      <span>👥</span> Пользователи <span class="badge" id="users-count">0</span>
    </div>
    <div class="nav-item" onclick="setView('billing')" id="nav-billing">
      <span>💳</span> Биллинг
    </div>

    <div class="sidebar-head" style="margin-top:12px">Агенты</div>
    <div class="nav-item" id="agent-matrix-nav">
      <span>🧠</span> Agent Matrix
      <div class="node-status ok" style="margin-left:auto"></div>
    </div>
    <div class="nav-item" id="agent-neo-nav">
      <span>🟣</span> Agent Neo
      <div class="node-status" style="margin-left:auto"></div>
    </div>
    <div class="nav-item" id="fish-nav">
      <span>🎣</span> Fish Module
      <div class="node-status" style="margin-left:auto" id="fish-status-dot"></div>
    </div>

    <div class="sidebar-stats">
      <div class="stat-row">
        <span>CPU</span>
        <div class="stat-bar"><div class="stat-fill" id="cpu-bar" style="width:0%;background:var(--accent)"></div></div>
        <span id="cpu-val" style="font-size:11px;min-width:30px">-</span>
      </div>
      <div class="stat-row">
        <span>RAM</span>
        <div class="stat-bar"><div class="stat-fill" id="ram-bar" style="width:0%;background:var(--purple)"></div></div>
        <span id="ram-val" style="font-size:11px;min-width:30px">-</span>
      </div>
      <div class="stat-row" style="font-size:11px;color:var(--text3);padding-top:6px;padding-bottom:10px">
        <span>⏱ Uptime: <span id="uptime-val">—</span></span>
      </div>
    </div>
  </div>

  <!-- CANVAS -->
  <div id="canvas-area">
    <div class="canvas-bg"></div>
    <div id="flow-canvas">
      <svg id="edges-svg"><defs>
        <marker id="arr" markerWidth="8" markerHeight="6" refX="6" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="#253352"/>
        </marker>
        <marker id="arr-a" markerWidth="8" markerHeight="6" refX="6" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--accent)"/>
        </marker>
      </defs></svg>
      <div id="nodes-layer"></div>
    </div>
    <div class="canvas-controls">
      <div class="canvas-btn" onclick="zoom(0.15)" title="Увеличить">+</div>
      <div class="canvas-btn" onclick="zoom(-0.15)" title="Уменьшить">−</div>
      <div class="canvas-btn" onclick="fitView()" title="Сброс">⊡</div>
      <div class="canvas-btn" onclick="addNodeMenu()" title="Добавить узел">⊕</div>
    </div>
    <div class="minimap" id="minimap"></div>

    <!-- VIEWS (non-canvas) -->
    <div id="view-tools" style="display:none;position:absolute;inset:0;overflow-y:auto;padding:16px">
      <h2 style="font-size:16px;font-weight:700;margin-bottom:14px">🔧 Библиотека инструментов</h2>
      <div class="tools-grid" id="tools-grid-main">
        <div class="add-tool-btn" onclick="openAddTool()">+ Добавить инструмент</div>
      </div>
    </div>
    <div id="view-tunnel" style="display:none;position:absolute;inset:0;overflow-y:auto;padding:16px">
      <h2 style="font-size:16px;font-weight:700;margin-bottom:14px">🌐 Управление туннелями</h2>
      <div id="tunnel-view-content"></div>
    </div>
    <div id="view-users" style="display:none;position:absolute;inset:0;overflow-y:auto;padding:16px">
      <h2 style="font-size:16px;font-weight:700;margin-bottom:14px">👥 Пользователи</h2>
      <div id="users-table"></div>
    </div>
    <div id="view-billing" style="display:none;position:absolute;inset:0;overflow-y:auto;padding:16px">
      <h2 style="font-size:16px;font-weight:700;margin-bottom:14px">💳 Биллинг</h2>
      <div id="billing-content"></div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div id="right-panel">
    <div class="panel-tabs">
      <div class="panel-tab active" onclick="setRightTab('logs')" id="tab-logs">📋 Логи</div>
      <div class="panel-tab" onclick="setRightTab('ai')" id="tab-ai">🤖 AI</div>
      <div class="panel-tab" onclick="setRightTab('info')" id="tab-info">📊 Метрики</div>
    </div>
    <!-- LOGS -->
    <div class="panel-content" id="panel-logs">
      <div id="logs-panel"></div>
    </div>
    <!-- AI CHAT -->
    <div id="panel-ai" style="display:none;flex-direction:column;height:calc(100% - 42px)">
      <div id="ai-messages"></div>
      <div id="ai-chat-input">
        <textarea id="ai-chat-text" placeholder="Задай задачу AI агенту..." onkeydown="aiChatKey(event)"></textarea>
        <button class="btn primary" onclick="aiChatSend()" style="align-self:flex-end;height:36px">→</button>
      </div>
    </div>
    <!-- METRICS -->
    <div class="panel-content" id="panel-info" style="display:none">
      <div class="metrics-grid" id="metrics-grid">
        <div class="metric-card"><div class="metric-label">CPU</div><div class="metric-val" id="m-cpu">—</div><div class="metric-bar"><div class="metric-fill" id="mf-cpu" style="width:0%"></div></div></div>
        <div class="metric-card"><div class="metric-label">RAM</div><div class="metric-val" id="m-ram">—</div><div class="metric-bar"><div class="metric-fill" id="mf-ram" style="width:0%"></div></div></div>
        <div class="metric-card"><div class="metric-label">Инструменты</div><div class="metric-val" id="m-tools">0</div></div>
        <div class="metric-card"><div class="metric-label">Сессий</div><div class="metric-val" id="m-sessions">0</div></div>
        <div class="metric-card" style="grid-column:1/-1"><div class="metric-label">Uptime</div><div class="metric-val" id="m-uptime" style="font-size:16px">—</div></div>
      </div>
    </div>
  </div>
</div>

<!-- TOASTS -->
<div id="toasts"></div>

<!-- MODALS -->
<div id="add-tool-modal" class="overlay" style="display:none" onclick="if(event.target===this)hideModal('add-tool-modal')">
  <div class="modal">
    <h3>🔧 Новый инструмент</h3>
    <div class="steps-indicator">
      <div class="step-dot done" id="s1"></div>
      <div class="step-dot" id="s2"></div>
      <div class="step-dot" id="s3"></div>
      <div class="step-dot" id="s4"></div>
    </div>
    <div id="tool-step-1">
      <div class="field">
        <label>Имя инструмента или GitHub URL</label>
        <input id="tool-name" placeholder="robin / sherlock / https://github.com/user/repo" oninput="detectToolType()">
      </div>
      <div id="tool-type-hint" style="font-size:12px;color:var(--text2);margin-bottom:12px;padding:8px 12px;background:var(--card);border-radius:6px;display:none"></div>
      <div class="field">
        <label>Описание (или провокационный запрос)</label>
        <textarea id="tool-desc" placeholder="OSINT инструмент для поиска по username&#10;— или —&#10;Установи robin для разведки в социальных сетях"></textarea>
      </div>
      <div class="field">
        <label>Режим установки</label>
        <select id="tool-mode">
          <option value="auto">🤖 Auto (AI решает)</option>
          <option value="llm">⚡ LLM — генерация кода</option>
          <option value="github">🐙 GitHub — клонирование</option>
          <option value="pip">📦 Pip — пакет Python</option>
        </select>
      </div>
    </div>
    <div id="tool-step-2" style="display:none">
      <div class="field">
        <label>Пример входных данных (JSON)</label>
        <textarea id="tool-inputs" style="min-height:100px;font-family:monospace">{}</textarea>
      </div>
      <div class="field">
        <label>Тестовый запрос (необязательно)</label>
        <input id="tool-test-input" placeholder="Что протестировать?">
      </div>
    </div>
    <div id="tool-step-3" style="display:none">
      <div class="install-stages" id="install-stages-list"></div>
      <div style="font-size:12px;color:var(--text2);margin-top:8px" id="install-output"></div>
    </div>
    <div id="tool-step-4" style="display:none;text-align:center;padding:20px 0">
      <div style="font-size:48px;margin-bottom:12px">✅</div>
      <div style="font-size:16px;font-weight:700;color:var(--green)">Инструмент установлен!</div>
      <div style="font-size:13px;color:var(--text2);margin-top:8px" id="tool-success-name"></div>
    </div>
    <div class="modal-actions" id="tool-modal-actions">
      <button class="btn" onclick="hideModal('add-tool-modal')">Отмена</button>
      <button class="btn primary" onclick="toolWizardNext()">Далее →</button>
    </div>
  </div>
</div>

<div id="system-modal" class="overlay" style="display:none" onclick="if(event.target===this)hideModal('system-modal')">
  <div class="modal">
    <h3>⚙️ Система</h3>
    <div class="metrics-grid" id="sys-metrics" style="margin-bottom:16px"></div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <button class="btn danger" onclick="confirmAction('restart','Перезапустить бот?','/api/bot/restart')">🔄 Перезапустить бот</button>
      <button class="btn" onclick="apiCall('GET','/api/matrix/tools').then(loadTools)">♻️ Перезагрузить инструменты</button>
      <button class="btn" onclick="exportLogs()">📤 Экспорт логов</button>
    </div>
    <div class="modal-actions"><button class="btn" onclick="hideModal('system-modal')">Закрыть</button></div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════════
// CONFIG & STATE
// ══════════════════════════════════════════════════════
const TOKEN = new URLSearchParams(location.search).get('token') || localStorage.getItem('bba_token') || '';
const API = '';
let ws = null, wsReconnTimer = null;
let scale = 1, panX = 0, panY = 0;
let dragNode = null, dragStart = {x:0,y:0}, nodePos = {x:0,y:0};
let isPanning = false, panStart = {x:0,y:0};
let toolWizardStep = 1, installPollTimer = null;
let currentView = 'flow';
let connectedUsers = {};
let tools = [];
let stats = {};
let logAutoScroll = true;
const COLORS = ['#4f8cff','#00e5a0','#ffd166','#b48bff','#ff4d6a','#00d4ff'];

// Persistent token
if(TOKEN) localStorage.setItem('bba_token', TOKEN);

// ══════════════════════════════════════════════════════
// API
// ══════════════════════════════════════════════════════
async function apiCall(method, path, body) {
  try {
    const opts = {method, headers:{'X-Admin-Token': TOKEN, 'Content-Type':'application/json'}};
    if(body) opts.body = JSON.stringify(body);
    const r = await fetch(API + path, opts);
    if(r.status===401){toast('❌ Не авторизован — проверь токен','err');return null;}
    return await r.json();
  } catch(e) { return null; }
}

// ══════════════════════════════════════════════════════
// WEBSOCKET — REALTIME
// ══════════════════════════════════════════════════════
function initWS() {
  const proto = location.protocol==='https:'?'wss':'ws';
  ws = new WebSocket(`${proto}://${location.host}/ws/admin?token=${TOKEN}`);
  ws.onopen = () => { clearTimeout(wsReconnTimer); addLog('INFO','🔌 WebSocket подключён'); setGlobalStatus(true); };
  ws.onclose = () => { setGlobalStatus(false); wsReconnTimer = setTimeout(initWS, 3000); };
  ws.onerror = () => { setGlobalStatus(false); };
  ws.onmessage = e => {
    try {
      const d = JSON.parse(e.data);
      if(d.type==='log') addLog(d.level||'INFO', d.text, d.ts);
      if(d.type==='stats') updateStats(d);
      if(d.type==='tools') loadToolsData(d.tools);
      if(d.type==='cursor') updateCollabCursor(d);
      if(d.type==='tool_status') updateToolInstallStatus(d);
    } catch(_){}
  };
}

function wsSend(data) { if(ws && ws.readyState===1) ws.send(JSON.stringify(data)); }

// ══════════════════════════════════════════════════════
// COLLAB CURSORS (Figma-style)
// ══════════════════════════════════════════════════════
function initCursorBroadcast() {
  const canvas = document.getElementById('flow-canvas');
  canvas.addEventListener('mousemove', e => {
    wsSend({type:'cursor', x: (e.clientX - panX)/scale, y: (e.clientY - panY)/scale});
  });
}

function updateCollabCursor(d) {
  let el = document.getElementById('cursor_'+d.uid);
  if(!el) {
    el = document.createElement('div');
    el.className = 'collab-cursor';
    el.id = 'cursor_'+d.uid;
    const color = COLORS[Object.keys(connectedUsers).length % COLORS.length];
    connectedUsers[d.uid] = {color};
    el.innerHTML = `<div class="collab-cursor-arrow" style="border-color:transparent transparent ${color} transparent"></div>
      <div class="collab-cursor-label" style="background:${color};color:#fff">${d.name||'User'}</div>`;
    el.style.position = 'absolute';
    document.getElementById('nodes-layer').appendChild(el);
    // Add avatar
    const av = document.createElement('div');
    av.className = 'collab-av'; av.title = d.name||'User';
    av.style.background = color; av.textContent = (d.name||'U')[0];
    document.getElementById('collab-avatars').appendChild(av);
  }
  el.style.left = (d.x * scale + panX) + 'px';
  el.style.top  = (d.y * scale + panY) + 'px';
}

// ══════════════════════════════════════════════════════
// FLOW CANVAS
// ══════════════════════════════════════════════════════
const nodesData = {
  'bot':    {id:'bot',   icon:'🤖', title:'Telegram Bot',  x:80,  y:80,  status:'ok', desc:'Основной бот'},
  'matrix': {id:'matrix',icon:'🧠', title:'Agent Matrix',  x:320, y:80,  status:'ok', desc:'Автономный агент v2'},
  'neo':    {id:'neo',   icon:'🟣', title:'Agent Neo',     x:560, y:80,  status:'ok', desc:'NEO агент'},
  'fish':   {id:'fish',  icon:'🎣', title:'Fish Module',   x:80,  y:250, status:'ok', desc:'Фишинг :5100'},
  'tools':  {id:'tools', icon:'🔧', title:'Tool Library',  x:320, y:250, status:'ok', desc:'Динамические тулзы'},
  'tunnel': {id:'tunnel',icon:'🌐', title:'Tunnel',        x:560, y:250, status:'err',desc:'Cloudflared / Bore'},
  'db':     {id:'db',   icon:'🗄️', title:'Database',      x:320, y:420, status:'ok', desc:'SQLite / Sessions'},
  'admin':  {id:'admin', icon:'🖥️', title:'Admin Web',    x:560, y:420, status:'ok', desc:'Port: 8080'},
};

const edgesData = [
  {from:'bot',to:'matrix'},{from:'bot',to:'fish'},{from:'matrix',to:'tools'},
  {from:'matrix',to:'db'},{from:'admin',to:'tunnel'},{from:'fish',to:'tunnel'},
  {from:'bot',to:'neo'},{from:'neo',to:'tools'},
];

function renderCanvas() {
  const layer = document.getElementById('nodes-layer');
  const svg = document.getElementById('edges-svg');
  layer.innerHTML = '';
  svg.innerHTML = svg.querySelector('defs').outerHTML;

  Object.values(nodesData).forEach(n => {
    const div = document.createElement('div');
    div.className = `node ${n.status==='err'?'error':''}`;
    div.id = 'node_'+n.id;
    div.style.left = n.x+'px'; div.style.top = n.y+'px';
    div.innerHTML = `
      <div class="node-port in" data-node="${n.id}" data-dir="in"></div>
      <div class="node-head">
        <span class="node-icon">${n.icon}</span>
        <span class="node-title">${n.title}</span>
        <div class="node-status ${n.status==='ok'?'ok':'err'}"></div>
      </div>
      <div class="node-body">${n.desc}</div>
      <div class="node-actions">
        <button class="node-btn" onclick="nodeRun('${n.id}')">▶ Run</button>
        <button class="node-btn" onclick="nodeInfo('${n.id}')">ℹ Info</button>
      </div>
      <div class="node-port out" data-node="${n.id}" data-dir="out"></div>`;
    makeDraggable(div, n);
    layer.appendChild(div);
  });

  edgesData.forEach(e => drawEdge(e.from, e.to));
  applyTransform();
}

function drawEdge(fromId, toId) {
  const fn = nodesData[fromId], tn = nodesData[toId];
  if(!fn||!tn) return;
  const fw=200, fh=90;
  const x1=fn.x+fw, y1=fn.y+fh/2;
  const x2=tn.x,    y2=tn.y+fh/2;
  const cx = (x1+x2)/2;
  const path = document.createElementNS('http://www.w3.org/2000/svg','path');
  path.setAttribute('class','edge');
  path.setAttribute('d',`M${x1},${y1} C${cx},${y1} ${cx},${y2} ${x2},${y2}`);
  path.setAttribute('marker-end','url(#arr)');
  document.getElementById('edges-svg').appendChild(path);
}

function applyTransform() {
  const layer = document.getElementById('nodes-layer');
  layer.style.transform = `translate(${panX}px,${panY}px) scale(${scale})`;
}

function zoom(delta) {
  scale = Math.max(0.3, Math.min(2.5, scale + delta));
  applyTransform();
}

function fitView() {
  scale=1; panX=40; panY=20;
  applyTransform();
}

function makeDraggable(el, nodeRef) {
  el.addEventListener('mousedown', e => {
    if(e.target.classList.contains('node-port')||e.target.tagName==='BUTTON') return;
    e.preventDefault();
    dragNode = nodeRef;
    dragStart = {x: e.clientX, y: e.clientY};
    nodePos   = {x: nodeRef.x, y: nodeRef.y};
    el.classList.add('selected');
    document.querySelectorAll('.node').forEach(n=>{ if(n!==el) n.classList.remove('selected'); });
  });
}

document.addEventListener('mousemove', e => {
  if(!dragNode) {
    if(!isPanning) return;
    panX += e.clientX - panStart.x; panY += e.clientY - panStart.y;
    panStart = {x:e.clientX,y:e.clientY};
    applyTransform(); return;
  }
  const dx = (e.clientX - dragStart.x)/scale;
  const dy = (e.clientY - dragStart.y)/scale;
  dragNode.x = nodePos.x+dx; dragNode.y = nodePos.y+dy;
  const el = document.getElementById('node_'+dragNode.id);
  el.style.left = dragNode.x+'px'; el.style.top = dragNode.y+'px';
  redrawEdges();
});

document.addEventListener('mouseup', () => { dragNode=null; isPanning=false; });

document.getElementById('canvas-area').addEventListener('mousedown', e => {
  if(e.target.id==='flow-canvas'||e.target.classList.contains('canvas-bg')) {
    isPanning=true; panStart={x:e.clientX,y:e.clientY};
  }
});

document.getElementById('canvas-area').addEventListener('wheel', e => {
  e.preventDefault();
  zoom(e.deltaY < 0 ? 0.1 : -0.1);
}, {passive:false});

function redrawEdges() {
  const svg = document.getElementById('edges-svg');
  [...svg.querySelectorAll('path')].forEach(p=>p.remove());
  edgesData.forEach(e=>drawEdge(e.from,e.to));
}

function nodeRun(id) {
  const node = nodesData[id];
  if(!node) return;
  addLog('INFO',`▶ Запуск узла: ${node.title}`);
  const el = document.getElementById('node_'+id);
  el.classList.add('running');
  apiCall('POST','/api/matrix/run',{task:`Запусти ${node.title}`, agent: id}).then(r=>{
    el.classList.remove('running');
    if(r?.ok) { addLog('INFO',`✅ ${node.title}: ${(r.output||'').slice(0,100)}`); toast('✅ '+node.title+' выполнен','ok'); }
    else addLog('ERROR',`❌ ${node.title}: ${r?.error||'ошибка'}`);
  });
}

function nodeInfo(id) {
  const n = nodesData[id];
  toast(`${n.icon} ${n.title}: ${n.desc}`);
}

// ══════════════════════════════════════════════════════
// VIEWS
// ══════════════════════════════════════════════════════
function setView(v) {
  currentView = v;
  ['flow','tools','tunnel','users','billing'].forEach(x=>{
    const el = document.getElementById('view-'+x);
    if(el) el.style.display = 'none';
  });
  document.getElementById('flow-canvas').style.display = v==='flow'?'block':'none';
  document.querySelector('.canvas-controls').style.display = v==='flow'?'flex':'none';
  document.getElementById('minimap').style.display = v==='flow'?'block':'none';
  ['flow','tools','tunnel','users','billing'].forEach(x=>{
    document.getElementById('nav-'+x)?.classList.toggle('active', x===v);
  });
  if(v!=='flow') {
    const el = document.getElementById('view-'+v);
    if(el) el.style.display = 'block';
    if(v==='tools') renderToolsView();
    if(v==='tunnel') renderTunnelView();
    if(v==='users') loadUsers();
    if(v==='billing') loadBilling();
  }
}

// ══════════════════════════════════════════════════════
// TOOLS
// ══════════════════════════════════════════════════════
async function loadTools() {
  const r = await apiCall('GET','/api/matrix/tools');
  if(r?.tools) { tools = r.tools; loadToolsData(r.tools); }
}

function loadToolsData(list) {
  tools = list || [];
  document.getElementById('tools-count').textContent = tools.length;
  document.getElementById('m-tools').textContent = tools.length;
}

function renderToolsView() {
  const grid = document.getElementById('tools-grid-main');
  grid.innerHTML = '';
  tools.forEach(t => {
    const c = document.createElement('div');
    c.className = 'tool-card';
    c.innerHTML = `<div class="tc-icon">🔧</div>
      <div class="tc-name">${t.name}</div>
      <div class="tc-desc">${(t.description||'').slice(0,60)}</div>
      <div class="tc-status"><span>●</span> ${t.builtin?'Встроен':'Пользовательский'}</div>`;
    c.onclick = () => runToolUI(t);
    grid.appendChild(c);
  });
  const add = document.createElement('div');
  add.className = 'add-tool-btn';
  add.onclick = openAddTool;
  add.innerHTML = '+ Добавить инструмент';
  grid.appendChild(add);
}

function runToolUI(tool) {
  const inputs = prompt(`Запустить "${tool.name}"\nВведите JSON inputs:`, '{}');
  if(inputs===null) return;
  let parsed; try{parsed=JSON.parse(inputs)}catch{toast('❌ Неверный JSON','err');return;}
  addLog('INFO',`▶ Запуск инструмента: ${tool.name}`);
  apiCall('POST','/api/matrix/tool/run',{name:tool.name, inputs:parsed}).then(r=>{
    if(r?.ok) { addLog('INFO',`✅ ${tool.name}: ${(r.output||'').slice(0,200)}`); toast('✅ Готово!','ok'); }
    else addLog('ERROR',`❌ ${tool.name}: ${r?.error||'ошибка'}`);
  });
}

// ══════════════════════════════════════════════════════
// TOOL WIZARD (Install Stages)
// ══════════════════════════════════════════════════════
function openAddTool() {
  toolWizardStep = 1;
  document.getElementById('tool-name').value='';
  document.getElementById('tool-desc').value='';
  document.getElementById('tool-inputs').value='{}';
  document.getElementById('tool-type-hint').style.display='none';
  showWizardStep(1);
  showModal('add-tool-modal');
}

function showWizardStep(n) {
  [1,2,3,4].forEach(i=>{
    document.getElementById('tool-step-'+i).style.display = i===n?'block':'none';
    document.getElementById('s'+i).classList.toggle('done', i<=n);
  });
  const actions = document.getElementById('tool-modal-actions');
  if(n===3) actions.style.display='none';
  else if(n===4) { actions.innerHTML='<button class="btn primary" onclick="hideModal(\'add-tool-modal\');renderToolsView()">Закрыть</button>'; actions.style.display='flex'; }
  else { actions.innerHTML='<button class="btn" onclick="hideModal(\'add-tool-modal\')">Отмена</button><button class="btn primary" onclick="toolWizardNext()">Далее →</button>'; actions.style.display='flex'; }
  toolWizardStep = n;
}

function detectToolType() {
  const v = document.getElementById('tool-name').value.trim();
  const hint = document.getElementById('tool-type-hint');
  if(!v){hint.style.display='none';return;}
  if(v.startsWith('https://github.com')){hint.textContent='🐙 GitHub репозиторий — будет клонирован';hint.style.display='block';document.getElementById('tool-mode').value='github';}
  else if(v.includes('/')){hint.textContent='📦 Pip пакет';hint.style.display='block';document.getElementById('tool-mode').value='pip';}
  else{hint.textContent='⚡ LLM будет генерировать код автоматически';hint.style.display='block';document.getElementById('tool-mode').value='auto';}
}

function toolWizardNext() {
  if(toolWizardStep===1){
    const name = document.getElementById('tool-name').value.trim();
    if(!name){toast('❌ Введите имя инструмента','err');return;}
    showWizardStep(2);
  } else if(toolWizardStep===2){
    startToolInstall();
  }
}

async function startToolInstall() {
  showWizardStep(3);
  const name = document.getElementById('tool-name').value.trim();
  const desc = document.getElementById('tool-desc').value.trim();
  const mode = document.getElementById('tool-mode').value;
  const inputsRaw = document.getElementById('tool-inputs').value;
  let inputs; try{inputs=JSON.parse(inputsRaw)}catch{inputs={};}

  const stages = [
    {id:'detect',  icon:'🔍', label:'Анализ запроса и определение типа'},
    {id:'fetch',   icon:'📥', label:'Загрузка / подготовка ресурсов'},
    {id:'gen',     icon:'⚡', label:'Генерация кода (LLM / GitHub)'},
    {id:'test',    icon:'🧪', label:'Тестирование в sandbox'},
    {id:'reg',     icon:'✅', label:'Регистрация инструмента'},
  ];

  const stageEl = document.getElementById('install-stages-list');
  stageEl.innerHTML = '';
  stages.forEach(s=>{
    const d=document.createElement('div');
    d.className='stage-item'; d.id='stage_'+s.id;
    d.innerHTML=`<span class="stage-icon">⏳</span><span>${s.label}</span>`;
    stageEl.appendChild(d);
  });

  // Animate stages while API call runs
  let si = 0;
  const nextStage = () => {
    if(si>0) { const prev=document.getElementById('stage_'+stages[si-1].id); prev.classList.add('stage-done'); prev.querySelector('.stage-icon').textContent='✅'; }
    if(si>=stages.length) return;
    const cur=document.getElementById('stage_'+stages[si].id); cur.classList.add('stage-active'); cur.querySelector('.stage-icon').textContent=stages[si].icon;
    si++;
  };
  nextStage();
  const stageTimer = setInterval(()=>{nextStage();},1800);

  try {
    const r = await apiCall('POST','/api/matrix/tool/create',{name, description:desc, example_inputs:inputs, install_mode:mode, github_url: name.startsWith('https://')?name:''});
    clearInterval(stageTimer);
    // Complete all stages
    while(si<=stages.length) nextStage();
    
    if(r?.ok!==false){
      document.getElementById('tool-success-name').textContent = name;
      showWizardStep(4);
      loadTools();
      toast('✅ Инструмент "'+name+'" установлен!','ok');
      addLog('INFO','✅ Новый инструмент создан: '+name);
    } else {
      document.getElementById('install-output').textContent='❌ '+(r?.error||'Ошибка установки');
      const last=document.getElementById('stage_'+stages[stages.length-1].id);
      last.classList.remove('stage-active'); last.classList.add('stage-error');
      const actions=document.getElementById('tool-modal-actions');
      actions.innerHTML='<button class="btn" onclick="hideModal(\'add-tool-modal\')">Закрыть</button><button class="btn primary" onclick="showWizardStep(1)">← Назад</button>';
      actions.style.display='flex';
    }
  } catch(e) {
    clearInterval(stageTimer);
    document.getElementById('install-output').textContent='❌ Ошибка подключения';
  }
}

// ══════════════════════════════════════════════════════
// AI BAR & CHAT
// ══════════════════════════════════════════════════════
function aiBarSend() {
  const txt = document.getElementById('ai-input').value.trim();
  if(!txt) return;
  document.getElementById('ai-input').value='';
  setRightTab('ai');
  aiSendMessage(txt);
}

document.getElementById('ai-input').addEventListener('keydown', e=>{ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();aiBarSend();}});

function aiChatKey(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();aiChatSend();} }

function aiChatSend() {
  const txt = document.getElementById('ai-chat-text').value.trim();
  if(!txt) return;
  document.getElementById('ai-chat-text').value='';
  aiSendMessage(txt);
}

function aiSendMessage(txt) {
  addAIMsg(txt, 'user');
  const thinking = addAIMsg('🤔 Анализирую задачу...','bot thinking');
  
  // Detect tool install intent
  const isInstall = /установи|поставь|добавь|install|setup/i.test(txt);
  
  apiCall('POST','/api/matrix/run',{task: txt}).then(r=>{
    thinking.remove();
    if(!r){addAIMsg('❌ Нет соединения с сервером','bot');return;}
    if(r.ok===false&&r.error){ addAIMsg('❌ '+r.error,'bot');return;}
    
    const output = r.output||r.result||JSON.stringify(r);
    addAIMsg(output.slice(0,1000)+(output.length>1000?'\n...(обрезано)':''),'bot');
    
    if(isInstall&&r.tool_created){
      toast('✅ Инструмент автоматически создан!','ok');
      loadTools();
    }
  });
}

function addAIMsg(text, cls) {
  const msgs = document.getElementById('ai-messages');
  const d = document.createElement('div');
  d.className = 'ai-msg '+(cls||'');
  d.textContent = text;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
  return d;
}

// ══════════════════════════════════════════════════════
// LOGS
// ══════════════════════════════════════════════════════
function addLog(level, text, ts) {
  const panel = document.getElementById('logs-panel');
  const entry = document.createElement('div');
  entry.className = 'log-entry '+(level||'INFO');
  const time = ts || new Date().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  entry.innerHTML = `<span class="log-ts">${time}</span>${escHtml(text)}`;
  panel.appendChild(entry);
  if(panel.children.length > 500) panel.removeChild(panel.firstChild);
  if(logAutoScroll) { const p=document.getElementById('panel-logs'); p.scrollTop=p.scrollHeight; }
}

function escHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ══════════════════════════════════════════════════════
// TUNNEL
// ══════════════════════════════════════════════════════
async function renderTunnelView() {
  const el = document.getElementById('tunnel-view-content');
  el.innerHTML = '<div style="color:var(--text2);font-size:13px">Загрузка...</div>';
  const r = await apiCall('GET','/api/tunnel');
  
  const tunnels = r?.tunnels || {};
  const cfStatus = tunnels.cloudflared || tunnels;
  const url = cfStatus.url || cfStatus.tunnel_url || '';
  const running = cfStatus.running || false;

  el.innerHTML = `
    <div class="tunnel-panel">
      <div style="display:flex;gap:8px;margin-bottom:14px">
        <button class="btn green" onclick="startTunnel('cloudflared')">⚡ Cloudflared</button>
        <button class="btn" onclick="startTunnel('bore')">🌀 Bore</button>
        <button class="btn danger" onclick="stopTunnel()">■ Стоп</button>
      </div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:8px">Статус: <span style="color:${running?'var(--green)':'var(--red)'}">${running?'● Активен':'○ Выключен'}</span></div>
      ${url?`
        <div class="tunnel-url-box">${url}</div>
        <div style="display:flex;gap:8px;margin-bottom:12px">
          <button class="btn" onclick="navigator.clipboard.writeText('${url}');toast('📋 Скопировано!')">📋 Копировать</button>
          <button class="btn" onclick="window.open('${url}','_blank')">🔗 Открыть</button>
        </div>`:'<div class="tunnel-url-box" style="color:var(--text3)">Туннель не запущен</div>'}
      <div style="font-size:12px;color:var(--text2);margin-top:16px;padding:12px;background:var(--card);border-radius:8px;border:1px solid var(--border)">
        <b>ℹ️ Информация о портах</b><br><br>
        🖥️ Admin Panel → порт <b>8080</b><br>
        🎣 Fish Module → порт <b>5100</b> (только внутренний, проксируется через /fish/)<br>
        🌐 Туннель → направлен на <b>8080</b> (единственный)<br><br>
        <span style="color:var(--green)">✅ Конфликт fish/admin-tunnel устранён</span>
      </div>
    </div>`;
}

async function startTunnel(provider) {
  addLog('INFO','🌐 Запуск туннеля: '+provider);
  const r = await apiCall('POST','/api/tunnel/start',{provider, port:8080});
  if(r?.ok!==false){ toast('✅ Туннель запускается...','ok'); setTimeout(()=>{ renderTunnelView(); loadStatus(); },3000); }
  else toast('❌ '+(r?.error||'Ошибка'),'err');
}

async function stopTunnel() {
  await apiCall('POST','/api/tunnel/stop',{});
  toast('⏹ Туннель остановлен');
  renderTunnelView();
  document.getElementById('tunnel-badge').textContent='⚡ Tunnel: OFF';
  document.getElementById('tunnel-badge').className='tunnel-badge';
}

function openTunnelPanel() { setView('tunnel'); }

// ══════════════════════════════════════════════════════
// STATUS POLLING
// ══════════════════════════════════════════════════════
async function loadStatus() {
  const r = await apiCall('GET','/api/status');
  if(!r) return;
  updateStats(r);
}

function updateStats(d) {
  stats = d;
  const cpu = d.cpu||0, ram = d.ram||0;
  document.getElementById('cpu-bar').style.width = cpu+'%';
  document.getElementById('ram-bar').style.width = ram+'%';
  document.getElementById('cpu-val').textContent = cpu+'%';
  document.getElementById('ram-val').textContent = ram+'%';
  document.getElementById('m-cpu').textContent = cpu+'%';
  document.getElementById('m-ram').textContent = ram+'%';
  document.getElementById('mf-cpu').style.width = cpu+'%';
  document.getElementById('mf-ram').style.width = ram+'%';
  document.getElementById('mf-cpu').className = 'metric-fill'+(cpu>90?' crit':cpu>70?' warn':'');
  document.getElementById('mf-ram').className = 'metric-fill'+(ram>90?' crit':ram>70?' warn':'');
  
  if(d.uptime_str){ document.getElementById('uptime-val').textContent=d.uptime_str; document.getElementById('m-uptime').textContent=d.uptime_str; }
  if(d.users_count!==undefined){ document.getElementById('users-count').textContent=d.users_count; document.getElementById('m-sessions').textContent=d.sessions||0; }
  
  const tunnel = d.tunnel_url||d.tunnel;
  if(tunnel){ document.getElementById('tunnel-badge').textContent='⚡ '+tunnel.replace('https://','').slice(0,24)+'...'; document.getElementById('tunnel-badge').className='tunnel-badge active'; }

  // Update node statuses
  if(d.bot_ok!==undefined) { nodesData.bot.status = d.bot_ok?'ok':'err'; const el=document.getElementById('node_bot'); if(el){el.className='node '+(d.bot_ok?'':'error');el.querySelector('.node-status').className='node-status '+(d.bot_ok?'ok':'err');} }
}

async function loadUsers() {
  const r = await apiCall('GET','/api/users');
  const el = document.getElementById('users-table');
  if(!r?.users){el.innerHTML='<div style="color:var(--text2);padding:12px">Нет данных</div>';return;}
  const rows = r.users.slice(0,50).map(u=>`
    <tr style="border-bottom:1px solid var(--border)">
      <td style="padding:8px;font-size:13px">${u.telegram_id||u.id}</td>
      <td style="padding:8px;font-size:13px">${u.username||'—'}</td>
      <td style="padding:8px"><span style="color:${u.is_banned?'var(--red)':'var(--green)'};font-size:12px">${u.is_banned?'Banned':'Active'}</span></td>
      <td style="padding:8px;font-size:12px">${u.privilege||0}</td>
      <td style="padding:8px"><button class="btn danger" style="padding:2px 8px;font-size:11px" onclick="banUser(${u.telegram_id||u.id})">Ban</button></td>
    </tr>`).join('');
  el.innerHTML = `<table style="width:100%;border-collapse:collapse"><thead><tr style="font-size:11px;color:var(--text2)"><th style="padding:8px;text-align:left">ID</th><th style="padding:8px;text-align:left">Username</th><th style="padding:8px;text-align:left">Статус</th><th style="padding:8px;text-align:left">Уровень</th><th style="padding:8px;text-align:left">Действия</th></tr></thead><tbody>${rows}</tbody></table>`;
}

async function banUser(id) {
  if(!confirm('Забанить '+id+'?')) return;
  const r = await apiCall('POST','/api/users/ban',{telegram_id:id});
  if(r?.ok!==false) toast('✅ Пользователь забанен','ok');
  loadUsers();
}

async function loadBilling() {
  const r = await apiCall('GET','/api/billing/stats');
  const el = document.getElementById('billing-content');
  if(!r) { el.innerHTML='<div style="color:var(--text2);padding:12px">Биллинг не настроен</div>'; return; }
  el.innerHTML = `<div class="metrics-grid">
    <div class="metric-card"><div class="metric-label">Всего запросов</div><div class="metric-val">${r.total_requests||0}</div></div>
    <div class="metric-card"><div class="metric-label">Активных пользователей</div><div class="metric-val">${r.active_users||0}</div></div>
  </div>`;
}

// ══════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════
function setGlobalStatus(ok) {
  const dot = document.getElementById('global-dot');
  dot.style.background = ok?'var(--green)':'var(--red)';
  dot.style.boxShadow = ok?'0 0 8px var(--green)':'0 0 8px var(--red)';
}

function setRightTab(tab) {
  ['logs','ai','info'].forEach(t=>{
    document.getElementById('tab-'+t).classList.toggle('active',t===tab);
    const p=document.getElementById('panel-'+t);
    if(p) p.style.display = t===tab?(t==='ai'?'flex':'block'):'none';
  });
}

function showModal(id) { document.getElementById(id).style.display='flex'; }
function hideModal(id) { document.getElementById(id).style.display='none'; }

function toast(msg, type) {
  const el=document.createElement('div');
  el.className='toast '+(type||'');
  el.textContent=msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(()=>el.remove(),3500);
}

function confirmAction(action, msg, url) {
  if(!confirm(msg)) return;
  apiCall('POST',url,{}).then(r=>{ toast(r?.ok!==false?'✅ Готово':'❌ Ошибка', r?.ok!==false?'ok':'err'); });
}

function exportLogs() {
  const logs = [...document.querySelectorAll('.log-entry')].map(e=>e.textContent).join('\n');
  const a=document.createElement('a');
  a.href='data:text/plain;charset=utf-8,'+encodeURIComponent(logs);
  a.download='blackbugs_logs_'+Date.now()+'.txt';
  a.click();
}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  renderCanvas();
  fitView();
  initWS();
  initCursorBroadcast();
  loadStatus();
  loadTools();
  
  // Poll status every 10s
  setInterval(loadStatus, 10000);
  // Poll logs if WS not connected
  setInterval(async()=>{
    if(ws?.readyState!==1){
      const r=await apiCall('GET','/api/logs?limit=20');
      if(r?.logs) r.logs.forEach(l=>addLog(l.level,l.text,l.ts));
    }
  },5000);
  
  addLog('INFO','🖤🐛 BlackBugsAI Control Matrix v4.0 загружен');
  addLog('INFO','⚡ Ожидание подключения к серверу...');
});
</script>
</body>
</html>
