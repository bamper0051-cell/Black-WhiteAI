# ╔══════════════════════════════════════════════════════╗
# ║           BlackBugsAI — Configuration               ║
# ╚══════════════════════════════════════════════════════╝

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# ── LLM ──────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=sk-or-...
PLANNER_MODEL=openai/gpt-4o
EXECUTOR_MODEL=openai/gpt-4o-mini

# ── LLM Keys ─────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# ── Admin Web ─────────────────────────────────────────
ADMIN_WEB_PORT=8080
ADMIN_WEB_TOKEN=CHANGE_ME_strong_secret

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_jwt_secret_key
JWT_EXPIRE_HOURS=24

# ── Billing ───────────────────────────────────────────
BILLING_ENABLED=false
BILLING_PROVIDER=telegram_stars
# STRIPE_SECRET_KEY=sk_live_...

# ── Proxy / Tor ───────────────────────────────────────
PROXY_ENABLED=false
PROXY_URL=
# PROXY_URL=http://user:pass@proxy-host:8080
# PROXY_URL=socks5://proxy-host:1080
PROXY_ROTATE=false
PROXY_LIST_FILE=
TOR_ENABLED=false
TOR_PORT=9050

# ── TTS ───────────────────────────────────────────────
TTS_PROVIDER=edge
TTS_VOICE=ru-RU-DmitryNeural
ELEVEN_API_KEY=

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///data/blackbugsai.db
DATA_DIR=data

# ── Queue ─────────────────────────────────────────────
QUEUE_WORKERS=2
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# ── Sandbox ───────────────────────────────────────────
DOCKER_SANDBOX=false

# ── Server ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
