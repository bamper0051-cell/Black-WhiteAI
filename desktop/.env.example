# BlackBugsAI Configuration Template
# Copy this to .env and fill in your values

# ????????????????????????????????????????????????????????????????????????????
# AI PROVIDER API KEYS
# ????????????????????????????????????????????????????????????????????????????

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (get from https://console.anthropic.com/account/keys)
# ANTHROPIC_API_KEY=sk-ant-...

# ????????????????????????????????????????????????????????????????????????????
# LOCAL LLM CONFIGURATION
# ????????????????????????????????????????????????????????????????????????????

# Ollama base URL (if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Local GGUF model path (absolute path to .gguf file)
# LOCAL_MODEL_PATH=C:\Users\YourName\Models\mistral-7b.gguf

# ????????????????????????????????????????????????????????????????????????????
# SANDBOX CONFIGURATION
# ????????????????????????????????????????????????????????????????????????????

# Enable/disable code execution sandbox
ENABLE_SANDBOX=true

# Code execution timeout in seconds (10-120)
SANDBOX_TIMEOUT=30

# Memory limit for code execution in MB (256-2048)
SANDBOX_MEMORY_LIMIT_MB=512

# ????????????????????????????????????????????????????????????????????????????
# API SERVER CONFIGURATION
# ????????????????????????????????????????????????????????????????????????????

# Enable local OpenAI-compatible API server
API_SERVER_ENABLED=false

# Port for API server
API_SERVER_PORT=8765

# ????????????????????????????????????????????????????????????????????????????
# TELEGRAM BOT CONFIGURATION
# ????????????????????????????????????????????????????????????????????????????

# Enable Telegram bot integration
TELEGRAM_ENABLED=false

# Telegram bot token (get from BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=123456:ABC...

# ????????????????????????????????????????????????????????????????????????????
# APPLICATION SETTINGS
# ????????????????????????????????????????????????????????????????????????????

# Enable debug mode
DEBUG=false

# Maximum context window length
MAX_CONTEXT_LENGTH=4096

# Maximum file attachment size in MB
MAX_FILE_SIZE_MB=100

# Default system prompt
# SYSTEM_PROMPT=You are a helpful AI assistant.

# ????????????????????????????????????????????????????????????????????????????
# ADVANCED SETTINGS
# ????????????????????????????????????????????????????????????????????????????

# Data directory (leave empty to use ~/.blackbugsai)
# DATA_DIR=C:\Users\YourName\BlackBugsAI

# Number of worker threads for async operations
WORKER_THREADS=4

# ????????????????????????????????????????????????????????????????????????????
# NOTES
# ????????????????????????????????????????????????????????????????????????????
# 
# 1. Keep this file secure - it contains API keys!
# 2. Never commit .env to version control
# 3. Uncomment settings you want to change
# 4. Boolean values: true/false (lowercase)
# 5. Paths can use forward slashes (/) on all platforms
# 6. Restart the application after changing settings
#
# For more information, see SETUP_GUIDE.md
