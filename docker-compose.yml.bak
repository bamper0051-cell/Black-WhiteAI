

services:
  blackbugs-main:
    image: blackbugsai:v3
    container_name: blackbugs-main
    restart: unless-stopped
    ports:
      - "8080:8080"
    networks:
      - blackbugs-net
    env_file:
      - .env
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/ || exit 1"]
      interval: 20s
      timeout: 10s
      retries: 5
      start_period: 40s

  blackbugs-nginx:
    image: nginx:alpine
    container_name: blackbugs-nginx
    restart: unless-stopped
    depends_on:
      blackbugs-main:
        condition: service_healthy
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - blackbugs-net

networks:
  blackbugs-net:
    driver: bridge
