# ============================================================
# BlackBugsAI — Environment Configuration
# Скопируй этот файл в .env и заполни свои значения
# ============================================================

# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ADMIN_IDS=123456789,987654321

# === Admin Web Panel ===
ADMIN_WEB_PORT=8080
ADMIN_WEB_TOKEN=CHANGE_ME_strong_secret
ADMIN_HOST=0.0.0.0

# === JWT Auth ===
JWT_SECRET=CHANGE_ME_another_long_random_string
JWT_EXPIRE_HOURS=24
SECRET_KEY=CHANGE_ME_flask_secret

# === LLM Providers (добавь хотя бы один) ===
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=

# === Специализированные LLM ===
CODE_PROVIDER=groq
CODE_MODEL=llama-3.3-70b-versatile
AGENT_PROVIDER=openrouter
AGENT_MODEL=deepseek/deepseek-chat

# === Vision ===
# Нужен хотя бы один Vision-совместимый ключ:
# OpenAI (GPT-4o), Anthropic (Claude), Gemini, OpenRouter

# === Ollama (локальные модели) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# === Data Storage ===
DATA_DIR=/app/data
BASE_DIR=/app

# === Fish Module ===
FISH_SERVER_PORT=5100
FISH_TUNNEL_DISABLED=true

# === Tunnel ===
TUNNEL_PROVIDER=cloudflared
TUNNEL_TARGET_PORT=80
AUTO_TUNNEL=false
BORE_SERVER=bore.pub
HTTP_PORT=80

# === TTS ===
TTS_PROVIDER=edge
TTS_VOICE=ru-RU-DmitryNeural
TTS_LANGUAGE=ru
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=
ELEVENLABS_API_KEY=

# === Media APIs ===
STABILITY_API_KEY=
HF_API_KEY=
REPLICATE_API_KEY=

# === Stable Diffusion WebUI ===
WEBUI_URL=http://localhost:7860

# === Billing ===
DEFAULT_PLAN=free
# free / pro / business / enterprise

# === Optional Proxy ===
USE_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=
USE_TOR=false

# === Misc ===
DEBUG=false
LOG_LEVEL=INFO
BRAND_NAME=BlackBugsAI
PYTHONUNBUFFERED=1
TZ=UTC

# === Direct Admin Port (debug only, в prod идёт через nginx) ===
ADMIN_DIRECT_PORT=8080
