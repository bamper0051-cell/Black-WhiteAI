# ════════════════════════════════════════════
#  АВТОМУВИ v4.4 — конфигурация
#  Скопируй в .env и заполни значения
# ════════════════════════════════════════════

# ── Telegram ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Администраторы ────────────────────────
ADMIN_IDS=123456789

# ── Admin Web Panel ────────────────────────
ADMIN_WEB_PORT=8080
ADMIN_WEB_TOKEN=CHANGE_ME_strong_secret

# ── LLM (хотя бы один ключ) ───────────────
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=

GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=

# ── Специализированные LLM ────────────────
CODE_PROVIDER=groq
CODE_MODEL=llama-3.3-70b-versatile
AGENT_PROVIDER=openrouter
AGENT_MODEL=deepseek/deepseek-chat

# ── Vision (анализ изображений) ───────────
# Нужен хотя бы один Vision-совместимый ключ:
# OpenAI (GPT-4o), Anthropic (Claude), Gemini, OpenRouter

# ── TTS ───────────────────────────────────
TTS_PROVIDER=edge
TTS_VOICE=ru-RU-DmitryNeural
TTS_LANGUAGE=ru
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=

# ── Изображения ───────────────────────────
STABILITY_API_KEY=
HF_API_KEY=

# ── Stable Diffusion WebUI ────────────────
WEBUI_URL=http://localhost:7860

# ── Веб-сервер ────────────────────────────
SERVER_HOST=0.0.0.0
FISH_SERVER_PORT=5000

# ── Расписание ────────────────────────────
PARSE_INTERVAL_HOURS=12
