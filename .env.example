# ============================================================
# BlackBugsAI — Environment Configuration Example
# Скопируй этот файл в .env и заполни свои значения
# ============================================================

# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# === LLM Providers (добавь хотя бы один) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
GOOGLE_API_KEY=...
TOGETHER_API_KEY=...
COHERE_API_KEY=...
DEEPSEEK_API_KEY=...
XAI_API_KEY=...
PERPLEXITY_API_KEY=...

# === Ollama (локальные модели) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# === Admin Web Panel ===
ADMIN_WEB_TOKEN=change_me_to_a_long_random_string
ADMIN_WEB_PORT=8080

# === JWT Auth ===
JWT_SECRET=change_me_to_another_long_random_string
JWT_EXPIRY_HOURS=24

# === Data Storage ===
DATA_DIR=/app/data
BASE_DIR=/app

# === Billing Defaults ===
DEFAULT_PLAN=free
# free / pro / business / enterprise

# === Media APIs ===
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_KEY=

# === Optional Proxy ===
USE_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=
USE_TOR=false

# === Tunnel (auto-expose via Cloudflare) ===
AUTO_TUNNEL=false

# === Misc ===
DEBUG=false
LOG_LEVEL=INFO
BRAND_NAME=BlackBugsAI
