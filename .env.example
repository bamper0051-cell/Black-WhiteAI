# ════════════════════════════════════════════════════════════════════════════
# BlackBugsAI — Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
ADMIN_IDS=123456789,987654321

# ── Admin Web Panel ───────────────────────────────────────────────────────
ADMIN_WEB_PORT=8080
ADMIN_WEB_TOKEN=CHANGE_ME_strong_secret_token
ADMIN_HOST=0.0.0.0
SECRET_KEY=blackbugs_change_in_prod

# ── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_another_long_random_string
JWT_EXPIRY_HOURS=24

# ── LLM Providers (add at least one) ──────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=

# Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=

# ── Specialized LLM ───────────────────────────────────────────────────────
CODE_PROVIDER=groq
CODE_MODEL=llama-3.3-70b-versatile
AGENT_PROVIDER=openrouter
AGENT_MODEL=deepseek/deepseek-chat

# ── Ollama (local models) ─────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Vision (image analysis) ───────────────────────────────────────────────
# Requires at least one Vision-compatible key:
# OpenAI (GPT-4o), Anthropic (Claude), Gemini, OpenRouter

# ── TTS (Text-to-Speech) ──────────────────────────────────────────────────
TTS_PROVIDER=edge
TTS_VOICE=ru-RU-DmitryNeural
TTS_LANGUAGE=ru
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=

# ── Image Generation ──────────────────────────────────────────────────────
STABILITY_API_KEY=
REPLICATE_API_KEY=
HF_API_KEY=

# ── Stable Diffusion WebUI ────────────────────────────────────────────────
WEBUI_URL=http://localhost:7860

# ── Database & Persistence ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=blackbugsai
POSTGRES_USER=blackbugs
POSTGRES_PASSWORD=CHANGE_ME_secure_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Data Storage ──────────────────────────────────────────────────────────
DATA_DIR=/app/data
BASE_DIR=/app

# ── Web Server ────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
HTTP_PORT=80
FISH_SERVER_PORT=5100
FISH_TUNNEL_DISABLED=true

# ── n8n Workflow Automation ───────────────────────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password

# ── Tunnel Configuration ──────────────────────────────────────────────────
TUNNEL_PROVIDER=cloudflared
TUNNEL_TARGET_PORT=80
AUTO_TUNNEL=false
BORE_SERVER=bore.pub

# ── Billing & Plans ───────────────────────────────────────────────────────
DEFAULT_PLAN=free
# Options: free / pro / business / enterprise

# ── Scheduling ────────────────────────────────────────────────────────────
PARSE_INTERVAL_HOURS=12

# ── Optional Proxy ────────────────────────────────────────────────────────
USE_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=
USE_TOR=false

# ── Miscellaneous ─────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
BRAND_NAME=BlackBugsAI
PYTHONUNBUFFERED=1
TZ=UTC
